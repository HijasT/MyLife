# ── Supabase ──────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=MyLife
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Optional: server-side Portfolio price cron ───────────────
# Only needed if you enable the Vercel Cron job in vercel.json
# (/api/cron/refresh-portfolio-prices).
# Service role key — Settings → API → service_role. Server-only, bypasses RLS: never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=
# Shared secret Vercel Cron sends as `Authorization: Bearer <value>` — set the same value in your Vercel project's env vars.
CRON_SECRET=
